generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProcessType {
  ENTRADA
  SAIDA
}

enum DueRuleType {
  OFFSET_DAYS
  DAY_OF_NEXT_MONTH
}

enum ItemStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDO
  NA
}

enum RoleName {
  ADMIN
  GESTOR_EMPRESA
  OPERADOR
  LEITURA
}

model Company {
  id            String   @id @default(cuid())
  cnpj          String   @unique
  razaoSocial   String?
  nomeFantasia  String?
  dataCadastro  DateTime @default(now())

  cod                   String?
  filial                String?
  grupo                 String?
  municipio             String?
  uf                    String?
  tributacao            String?
  ieAtual               String?
  dataTributacao        DateTime?
  motivoEntrada         String?
  situacao              String?
  dataSituacao          DateTime?
  ramo                  String?
  consultoria           String?
  banco                 String?
  perfil                String?
  licitacao             String?
  responsavelComercial  String?
  dataEntrada           DateTime?
  dataInicioCobranca    DateTime?
  dataFimCobranca       DateTime?
  motivoSaidaResumo     String?
  qtdeInicialFolha      Int?
  active        Boolean  @default(true)
  inactivatedAt DateTime?
  bloqueadoAt   DateTime?
  bloqueadoPor  String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  processRuns      ProcessRun[]
  responsibles       CompanySectorResponsible[]
  responsibleHistory CompanySectorResponsibleHistory[]
  partners           CompanyPartner[]

  @@map("Company")
}

model CompanyPartner {
  id              String   @id @default(cuid())
  companyId       String
  nomeCompleto    String?
  whatsapp        String?
  email           String?
  telefoneEmpresa String?
  dataNascimento  DateTime?
  outros          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("CompanyPartner")
}

model Sector {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  templateItems      ProcessTemplateItem[]         @relation("TemplateItemSector")
  responsibles       CompanySectorResponsible[]
  responsibleHistory CompanySectorResponsibleHistory[]

  @@map("Sector")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  active       Boolean  @default(true)
  sectorId     String?
  sector       Sector?  @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles             UserRole[]
  responsibles      CompanySectorResponsible[]
  responsibleHistory CompanySectorResponsibleHistory[]
  auditLogs         AuditLog[] @relation("AuditActor")

  @@map("User")
}

model Role {
  id    String   @id @default(cuid())
  name  RoleName @unique
  users UserRole[]

  @@map("Role")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, roleId])
  @@map("UserRole")
}

model ProcessTemplate {
  id        String        @id @default(cuid())
  type      ProcessType
  name      String
  version   Int           @default(1)
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  sections ProcessTemplateSection[]

  @@map("ProcessTemplate")
}

model ProcessTemplateSection {
  id         String @id @default(cuid())
  templateId String
  name       String
  order      Int    @default(0)

  template ProcessTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items    ProcessTemplateItem[]

  @@map("ProcessTemplateSection")
}

model ProcessTemplateItem {
  id                   String      @id @default(cuid())
  sectionId            String
  code                 String?
  description          String
  order                Int         @default(0)
  sectorId             String?
  isRequired           Boolean     @default(false)
  offsetDaysFromAnchor Int?
  dueRuleType          DueRuleType @default(OFFSET_DAYS)
  dueRuleParam         Int?

  section ProcessTemplateSection @relation(fields: [sectionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sector  Sector?                  @relation("TemplateItemSector", fields: [sectorId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@map("ProcessTemplateItem")
}

model ProcessRun {
  id                      String        @id @default(cuid())
  companyId               String
  templateId              String?
  type                    ProcessType
  createdBy               String
  anchorAt                DateTime?
  createdAt               DateTime      @default(now())
  snapshotTemplateName    String?
  snapshotTemplateVersion Int?

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items   ProcessItemRun[]

  @@map("ProcessRun")
}

model ProcessItemRun {
  id                         String      @id @default(cuid())
  runId                      String
  templateItemId             String?
  status                     ItemStatus  @default(PENDENTE)
  observation                String?
  dueDate                    DateTime?
  doneAt                     DateTime?
  doneBy                     String?
  overdueNotifiedAt          DateTime?
  snapshotSectionName        String?
  snapshotItemCode           String?
  snapshotItemDescription    String?
  snapshotItemOrder          Int?
  snapshotIsRequired         Boolean?
  snapshotSectorId           String?
  snapshotOffsetDaysFromAnchor Int?
  snapshotDueRuleType        DueRuleType?
  snapshotDueRuleParam       Int?

  run ProcessRun @relation(fields: [runId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([runId])
  @@map("ProcessItemRun")
}

model CompanySectorResponsible {
  id         String   @id @default(cuid())
  companyId  String
  sectorId   String
  userId     String
  assignedAt DateTime @default(now())
  assignedBy String

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sector  Sector  @relation(fields: [sectorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([companyId, sectorId])
  @@map("CompanySectorResponsible")
}

model CompanySectorResponsibleHistory {
  id        String   @id @default(cuid())
  companyId String
  sectorId  String
  userId    String
  startAt   DateTime @default(now())
  endAt     DateTime?
  changedBy String
  reason    String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sector  Sector  @relation(fields: [sectorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("CompanySectorResponsibleHistory")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  entity      String
  entityId    String?
  beforeJson  Json?
  afterJson   Json?
  createdAt   DateTime @default(now())
  ip          String?
  userAgent   String?

  actor User @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("AuditLog")
}

model NotificationConfig {
  id            String   @id @default(cuid())
  singletonKey  String   @unique @default("main")
  // URL do webhook do Teams (Power Automate/Workflows ou Incoming Webhook).
  webhookUrl    String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("NotificationConfig")
}
