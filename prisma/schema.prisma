generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChecklistType {
  ENTRADA
  SAIDA
}

enum DueRuleType {
  OFFSET_DAYS
  DAY_OF_NEXT_MONTH
}

enum ItemStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDO
  NA
}

enum RoleName {
  ADMIN
  GESTOR_EMPRESA
  OPERADOR
  LEITURA
}

model Company {
  id            String   @id @default(cuid())
  cnpj          String   @unique
  razaoSocial   String?
  nomeFantasia  String?
  dataCadastro  DateTime @default(now())

  cod                   String?
  filial                String?
  grupo                 String?
  tributacao            String?
  ieAtual               String?
  dataTributacao        DateTime?
  motivoEntrada         String?
  situacao              String?
  status                String?
  dataSituacao          DateTime?
  ramo                  String?
  consultoria           String?
  banco                 String?
  perfil                String?
  perfilComercial       String?
  licitacao             String?
  responsavelComercial  String?
  matrizFilial          String?
  observacoes           String?
  reunioesFechamentos   String?
  fechamentoContabil    String?
  analiseCompliance     String?
  cobrancaServExtras    Boolean?
  complexidadeFiscal    String?
  complexidadeContabil  String?
  informacoesNegociosMarketing String?
  dataEntrada           DateTime?
  dataSaida             DateTime?
  dataEntradaFiscal     DateTime?
  dataSaidaFiscal       DateTime?
  dataEntradaContabil   DateTime?
  dataSaidaContabil     DateTime?
  dataEntradaFolha      DateTime?
  dataSaidaFolha        DateTime?
  dataEntradaConsultoria DateTime?
  dataSaidaConsultoria  DateTime?
  dataInicioCobranca    DateTime?
  dataFimCobranca       DateTime?
  dataInicioCobrancaFiscal DateTime?
  dataFimCobrancaFiscal DateTime?
  dataInicioCobrancaContabil DateTime?
  dataFimCobrancaContabil DateTime?
  dataInicioCobrancaFolha DateTime?
  dataFimCobrancaFolha  DateTime?
  dataInicioCobrancaConsultoria DateTime?
  dataFimCobrancaConsultoria DateTime?
  motivoSaidaResumo     String?
  motivoSaida           String?
  qtdeInicialFolha      Int?
  prefeituraLogin       String?
  prefeituraSenha       String?
  sefazLogin            String?
  sefazSenha            String?
  blockedAt             DateTime?
  blockedBy             String?
  active        Boolean  @default(true)
  inactivatedAt DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  checklistRuns      ChecklistRun[]
  responsibles       CompanySectorResponsible[]
  responsibleHistory CompanySectorResponsibleHistory[]
  partners           CompanyPartner[]
  clientContacts     CompanyClientContact[]
  accessCredentials  CompanyAccessCredential[]

  @@map("Company")
}

model CompanyPartner {
  id              String   @id @default(cuid())
  companyId       String
  nomeCompleto    String?
  whatsapp        String?
  email           String?
  telefoneEmpresa String?
  dataNascimento  DateTime?
  outros          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("CompanyPartner")
}


model CompanyClientContact {
  id        String   @id @default(cuid())
  companyId String
  area      String
  nome      String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("CompanyClientContact")
}

model CompanyAccessCredential {
  id        String   @id @default(cuid())
  companyId String
  service   String
  login     String?
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, service])
  @@map("CompanyAccessCredential")
}

model Sector {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  templateItems      ChecklistTemplateItem[]         @relation("TemplateItemSector")
  responsibles       CompanySectorResponsible[]
  responsibleHistory CompanySectorResponsibleHistory[]

  @@map("Sector")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  active       Boolean  @default(true)
  sectorId     String?
  sector       Sector?  @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles             UserRole[]
  responsibles      CompanySectorResponsible[]
  responsibleHistory CompanySectorResponsibleHistory[]
  auditLogs         AuditLog[] @relation("AuditActor")

  @@map("User")
}

model Role {
  id    String   @id @default(cuid())
  name  RoleName @unique
  users UserRole[]

  @@map("Role")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, roleId])
  @@map("UserRole")
}

model ChecklistTemplate {
  id        String        @id @default(cuid())
  type      ChecklistType
  name      String
  version   Int           @default(1)
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  sections ChecklistTemplateSection[]

  @@map("ChecklistTemplate")
}

model ChecklistTemplateSection {
  id         String @id @default(cuid())
  templateId String
  name       String
  order      Int    @default(0)

  template ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items    ChecklistTemplateItem[]

  @@map("ChecklistTemplateSection")
}

model ChecklistTemplateItem {
  id                   String      @id @default(cuid())
  sectionId            String
  code                 String?
  description          String
  order                Int         @default(0)
  sectorId             String?
  isRequired           Boolean     @default(false)
  offsetDaysFromAnchor Int?
  dueRuleType          DueRuleType @default(OFFSET_DAYS)
  dueRuleParam         Int?

  section ChecklistTemplateSection @relation(fields: [sectionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sector  Sector?                  @relation("TemplateItemSector", fields: [sectorId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@map("ChecklistTemplateItem")
}

model ChecklistRun {
  id                      String        @id @default(cuid())
  companyId               String
  templateId              String?
  type                    ChecklistType
  createdBy               String
  anchorAt                DateTime?
  createdAt               DateTime      @default(now())
  snapshotTemplateName    String?
  snapshotTemplateVersion Int?

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items   ChecklistItemRun[]

  @@map("ChecklistRun")
}

model ChecklistItemRun {
  id                         String      @id @default(cuid())
  runId                      String
  templateItemId             String?
  status                     ItemStatus  @default(PENDENTE)
  observation                String?
  dueDate                    DateTime?
  doneAt                     DateTime?
  doneBy                     String?
  overdueNotifiedAt          DateTime?
  snapshotSectionName        String?
  snapshotItemCode           String?
  snapshotItemDescription    String?
  snapshotItemOrder          Int?
  snapshotIsRequired         Boolean?
  snapshotSectorId           String?
  snapshotOffsetDaysFromAnchor Int?
  snapshotDueRuleType        DueRuleType?
  snapshotDueRuleParam       Int?

  run ChecklistRun @relation(fields: [runId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([runId])
  @@map("ChecklistItemRun")
}

model CompanySectorResponsible {
  id         String   @id @default(cuid())
  companyId  String
  sectorId   String
  userId     String
  assignedAt DateTime @default(now())
  assignedBy String

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sector  Sector  @relation(fields: [sectorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([companyId, sectorId])
  @@map("CompanySectorResponsible")
}

model CompanySectorResponsibleHistory {
  id        String   @id @default(cuid())
  companyId String
  sectorId  String
  userId    String
  startAt   DateTime @default(now())
  endAt     DateTime?
  changedBy String
  reason    String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sector  Sector  @relation(fields: [sectorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("CompanySectorResponsibleHistory")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  entity      String
  entityId    String?
  beforeJson  Json?
  afterJson   Json?
  createdAt   DateTime @default(now())
  ip          String?
  userAgent   String?

  actor User @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("AuditLog")
}

model EmailAccountConfig {
  id            String   @id @default(cuid())
  singletonKey  String   @unique @default("main")
  host          String
  port          Int      @default(587)
  secure        Boolean  @default(false)
  username      String
  password      String
  fromEmail     String
  fromName      String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("EmailAccountConfig")
}
